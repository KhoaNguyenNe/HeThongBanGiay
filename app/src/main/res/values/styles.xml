<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.HeThongBanGiay.Button" parent="Widget.AppCompat.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/button_primary_text</item>
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">20dp</item>
    </style>

    <style name="Widget.HeThongBanGiay.MaterialButton" parent="Widget.HeThongBanGiay.Button" />

    <style name="Widget.HeThongBanGiay.MaterialButton.Secondary" parent="Widget.HeThongBanGiay.Button">
        <item name="android:textColor">@color/app_text_primary</item>
        <item name="android:background">@drawable/bg_button_secondary</item>
    </style>

    <style name="Widget.HeThongBanGiay.MaterialButton.Outlined" parent="Widget.HeThongBanGiay.Button">
        <item name="android:textColor">@color/app_text_primary</item>
        <item name="android:background">@drawable/bg_button_outlined</item>
    </style>

    <style name="Widget.HeThongBanGiay.MaterialButton.IconSurface" parent="Widget.HeThongBanGiay.MaterialButton.Outlined">
        <item name="android:minWidth">60dp</item>
        <item name="android:minHeight">60dp</item>
        <item name="android:background">@drawable/bg_button_icon_surface</item>
    </style>

    <style name="Widget.HeThongBanGiay.MaterialButton.Text" parent="Widget.AppCompat.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/app_primary</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingRight">0dp</item>
    </style>

    <style name="Widget.HeThongBanGiay.MaterialButton.FilterChip" parent="Widget.HeThongBanGiay.Button">
        <item name="android:textColor">@color/app_text_primary</item>
        <item name="android:background">@drawable/bg_button_filter_chip</item>
        <item name="android:minHeight">42dp</item>
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
        <item name="android:drawablePadding">6dp</item>
    </style>

    <style name="Widget.HeThongBanGiay.MaterialButton.FilterChip.Selected" parent="Widget.HeThongBanGiay.MaterialButton.FilterChip">
        <item name="android:background">@drawable/bg_button_filter_chip_selected</item>
    </style>

</resources>
