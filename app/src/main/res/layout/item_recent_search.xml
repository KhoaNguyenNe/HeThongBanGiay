<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="52dp"
    android:orientation="horizontal"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:contentDescription="Recent"
        android:src="@android:drawable/ic_menu_recent_history"
        app:tint="@color/app_text_secondary" />

    <TextView
        android:id="@+id/tvRecentKeyword"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:textColor="@color/app_text_primary"
        android:textSize="16sp" />

    <ImageView
        android:id="@+id/ivDeleteRecent"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:contentDescription="Delete recent item"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="@color/app_text_secondary" />
</LinearLayout>

