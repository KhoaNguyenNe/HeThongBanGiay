<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardAddress"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="?colorSurface"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="88dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <FrameLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_circle_primary_icon">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_location_pin"
                app:tint="@color/button_primary_text" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvAddressTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textColor="?android:textColorPrimary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvDefaultBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_badge_small"
                    android:gravity="center"
                    android:minWidth="50dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:text="Default"
                    android:textColor="?android:textColorPrimary"
                    android:textSize="10sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvAddressLine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="61480 Sunbrook Park, PC 5679"
                android:textColor="?android:textColorSecondary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnEditAddressItem"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="14dp"
                android:src="@drawable/ic_edit_18"
                app:tint="?android:textColorPrimary" />

            <ImageView
                android:id="@+id/btnDeleteAddressItem"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="14dp"
                android:src="@drawable/ic_delete_20"
                app:tint="?android:textColorPrimary" />

            <RadioButton
                android:id="@+id/rbAddress"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:buttonTint="?android:textColorPrimary"
                android:clickable="false"
                android:checked="true" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
