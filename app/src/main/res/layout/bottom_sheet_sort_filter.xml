<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <View
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@color/app_text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="Tìm kiếm"
            android:textColor="@color/app_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="@color/app_border" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Danh mục"
            android:textColor="@color/app_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp"
            app:singleSelection="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Mức giá"
            android:textColor="@color/app_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvMinPriceValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 đ"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvMaxPriceValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 đ"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <com.google.android.material.slider.RangeSlider
            android:id="@+id/rangePrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:valueFrom="0"
            android:valueTo="5000000"
            app:haloColor="@color/app_border"
            app:thumbColor="@color/app_text_primary"
            app:trackColorActive="@color/app_text_primary"
            app:trackColorInactive="@color/app_border" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
        android:text="Sắp xếp theo"
            android:textColor="@color/app_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupSort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSortPopular"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phổ biến"
                android:textColor="@color/chip_text_selector"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_bg_selector"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSortRecent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mới nhất"
                android:textColor="@color/chip_text_selector"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_bg_selector"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSortPriceHigh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giá cao"
                android:textColor="@color/chip_text_selector"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_bg_selector"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSortPriceLow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giá thấp"
                android:textColor="@color/chip_text_selector"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_bg_selector"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSortRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đánh giá"
                android:textColor="@color/chip_text_selector"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_bg_selector"
                app:chipStrokeWidth="0dp" />
        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
        android:text="Mức sao"
            android:textColor="@color/app_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupRating"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipRatingAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tất cả"
                android:textColor="@color/chip_text_selector"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_bg_selector"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipRating5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:textColor="@color/chip_text_selector"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_bg_selector"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipRating4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4+"
                android:textColor="@color/chip_text_selector"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_bg_selector"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipRating3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3+"
                android:textColor="@color/chip_text_selector"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_bg_selector"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipRating2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2+"
                android:textColor="@color/chip_text_selector"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_bg_selector"
                app:chipStrokeWidth="0dp" />
        </com.google.android.material.chip.ChipGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton style="@style/Widget.HeThongBanGiay.Button"
                android:id="@+id/btnReset"
               
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="Đặt lại" />

            <androidx.appcompat.widget.AppCompatButton style="@style/Widget.HeThongBanGiay.Button"
                android:id="@+id/btnApply"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Áp dụng" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
