<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:backgroundTint="@color/app_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- IMAGE -->
        <ImageView
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:src="@drawable/avatar"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_image"
            android:contentDescription="product_image"/>

        <!-- INFO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <!-- NAME -->
            <TextView
                android:id="@+id/txtCategoryName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tên sản phẩm"
                android:textColor="@color/app_text_primary"
                android:textStyle="bold"
                android:textSize="16sp"
                android:maxLines="2"/>

            <!-- COLOR + SIZE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/txtProductColor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Màu sắc"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/txtProductSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • Size"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="14sp"
                    android:layout_marginStart="8dp"/>


            </LinearLayout>
            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Màu sắc"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/txtExtra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • Size"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp"
                android:layout_marginStart="8dp"/>

            <!-- ADDRESS -->
            <TextView
                android:id="@+id/txtAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Địa chỉ giao hàng"
                android:textColor="@color/app_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="6dp"
                android:maxLines="2"/>

            <!-- PRICE + BUTTON -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtDMMoTa"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="1.000.000đ"
                    android:textColor="@color/app_primary"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <Button
                    android:id="@+id/btnCategoryChange"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Chi tiết"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    android:textColor="@color/button_primary_text"
                    android:backgroundTint="@color/button_primary_bg"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>

