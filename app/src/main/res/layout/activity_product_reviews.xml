<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/reviewRoot"
    android:background="@color/app_background"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="18dp"
    android:paddingEnd="16dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btnBackReview"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@android:color/transparent"
            android:contentDescription="Quay lại"
            android:src="@drawable/ic_arrow_left_24"
            android:tint="?android:textColorPrimary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:maxLines="1"
            android:text="Đánh giá sản phẩm"
            android:textColor="?android:textColorPrimary"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvReviewSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:maxLines="1"
        android:text="0.0 (0 đánh giá)"
        android:textColor="?android:textColorSecondary"
        android:textSize="14sp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton style="@style/Widget.HeThongBanGiay.Button"
                android:id="@+id/btnFilterAll"
               
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:drawablePadding="6dp"
                android:drawableStart="@android:drawable/btn_star_big_on"
                android:drawableTint="@color/app_rating"
                android:layout_marginEnd="10dp"
                android:minWidth="0dp"
                android:text="Tất cả" />

            <androidx.appcompat.widget.AppCompatButton style="@style/Widget.HeThongBanGiay.Button"
                android:id="@+id/btnFilter5"
               
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:drawablePadding="6dp"
                android:drawableStart="@android:drawable/btn_star_big_on"
                android:drawableTint="@color/app_rating"
                android:layout_marginEnd="10dp"
                android:minWidth="0dp"
                android:text="5" />

            <androidx.appcompat.widget.AppCompatButton style="@style/Widget.HeThongBanGiay.Button"
                android:id="@+id/btnFilter4"
               
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:drawablePadding="6dp"
                android:drawableStart="@android:drawable/btn_star_big_on"
                android:drawableTint="@color/app_rating"
                android:layout_marginEnd="10dp"
                android:minWidth="0dp"
                android:text="4" />

            <androidx.appcompat.widget.AppCompatButton style="@style/Widget.HeThongBanGiay.Button"
                android:id="@+id/btnFilter3"
               
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:drawablePadding="6dp"
                android:drawableStart="@android:drawable/btn_star_big_on"
                android:drawableTint="@color/app_rating"
                android:layout_marginEnd="10dp"
                android:minWidth="0dp"
                android:text="3" />

            <androidx.appcompat.widget.AppCompatButton style="@style/Widget.HeThongBanGiay.Button"
                android:id="@+id/btnFilter2"
               
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:drawablePadding="6dp"
                android:drawableStart="@android:drawable/btn_star_big_on"
                android:drawableTint="@color/app_rating"
                android:layout_marginEnd="10dp"
                android:minWidth="0dp"
                android:text="2" />

            <androidx.appcompat.widget.AppCompatButton style="@style/Widget.HeThongBanGiay.Button"
                android:id="@+id/btnFilter1"
               
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:drawablePadding="6dp"
                android:drawableStart="@android:drawable/btn_star_big_on"
                android:drawableTint="@color/app_rating"
                android:minWidth="0dp"
                android:text="1" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvEmptyReview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="Sản phẩm này chưa có đánh giá"
        android:textColor="?android:textColorSecondary"
        android:textSize="15sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProductReviews"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="16dp"
        android:scrollbars="none" />
</LinearLayout>