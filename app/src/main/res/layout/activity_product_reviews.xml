<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#181A20"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="18dp"
    android:paddingEnd="16dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnBackReview"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tvReviewSummary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:maxLines="1"
            android:text="4.8 (5,775 reviews)"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_search"
            android:tint="#FFFFFF" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilterAll"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginEnd="10dp"
                android:minWidth="0dp"
                android:text="All"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:backgroundTint="#2A2F3A"
                app:cornerRadius="21dp"
                app:elevation="0dp"
                app:icon="@android:drawable/btn_star_big_on"
                app:iconTint="#FFFFFF"
                app:strokeColor="#2A2F3A"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilter5"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginEnd="10dp"
                android:minWidth="0dp"
                android:text="5"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:backgroundTint="#181A20"
                app:cornerRadius="21dp"
                app:elevation="0dp"
                app:icon="@android:drawable/btn_star_big_on"
                app:iconTint="#FFFFFF"
                app:strokeColor="#4E535D"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilter4"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginEnd="10dp"
                android:minWidth="0dp"
                android:text="4"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:backgroundTint="#181A20"
                app:cornerRadius="21dp"
                app:elevation="0dp"
                app:icon="@android:drawable/btn_star_big_on"
                app:iconTint="#FFFFFF"
                app:strokeColor="#4E535D"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilter3"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginEnd="10dp"
                android:minWidth="0dp"
                android:text="3"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:backgroundTint="#181A20"
                app:cornerRadius="21dp"
                app:elevation="0dp"
                app:icon="@android:drawable/btn_star_big_on"
                app:iconTint="#FFFFFF"
                app:strokeColor="#4E535D"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilter2"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginEnd="10dp"
                android:minWidth="0dp"
                android:text="2"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:backgroundTint="#181A20"
                app:cornerRadius="21dp"
                app:elevation="0dp"
                app:icon="@android:drawable/btn_star_big_on"
                app:iconTint="#FFFFFF"
                app:strokeColor="#4E535D"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilter1"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:minWidth="0dp"
                android:text="1"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:backgroundTint="#181A20"
                app:cornerRadius="21dp"
                app:elevation="0dp"
                app:icon="@android:drawable/btn_star_big_on"
                app:iconTint="#FFFFFF"
                app:strokeColor="#4E535D"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvEmptyReview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="San pham nay chua co danh gia"
        android:textColor="#9EA3AF"
        android:textSize="15sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProductReviews"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:scrollbars="none" />
</LinearLayout>
