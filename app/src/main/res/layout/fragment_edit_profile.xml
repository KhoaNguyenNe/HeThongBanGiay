<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true"
    tools:context=".activities.EditProfileFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <include layout="@layout/view_header_title"/>

        <!-- AVATAR -->
        <ImageView
            android:id="@+id/imgAvatar"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:src="@drawable/avatar"
            android:scaleType="centerCrop"
            android:background="@drawable/circle_bg"
            android:clipToOutline="true"
            android:contentDescription="avatar"/>

        <TextView
            android:id="@+id/txtChangeAvatar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chọn ảnh đại diện mới"
            android:textAlignment="center"
            android:textColor="@color/app_text_secondary"
            android:textStyle="italic"
            android:layout_marginTop="6dp"/>

        <!-- FORM CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:backgroundTint="@color/app_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- USERNAME -->
                <EditText
                    android:id="@+id/edtUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nhập tên người dùng"
                    android:textColor="@color/app_text_primary"
                    android:textColorHint="@color/app_text_secondary"
                    android:background="@drawable/bg_input_profile"
                    android:padding="12dp"/>

                <!-- PHONE -->
                <EditText
                    android:id="@+id/edtPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input_profile"
                    android:hint="Nhập số điện thoại"
                    android:inputType="phone"
                    android:padding="12dp"
                    android:textColor="@color/app_text_primary"
                    android:textColorHint="@color/app_text_secondary" />

                <!-- EMAIL -->

                <!-- DOB -->
                <EditText
                    android:id="@+id/edtEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input_profile"
                    android:hint="Nhập email"
                    android:inputType="textEmailAddress"
                    android:padding="12dp"
                    android:textColor="@color/app_text_primary"
                    android:textColorHint="@color/app_text_secondary" />

                <EditText
                    android:id="@+id/edtDateOfBirth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ngày sinh"
                    android:textColor="@color/app_text_primary"
                    android:textColorHint="@color/app_text_secondary"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input_profile"
                    android:padding="12dp"
                    android:inputType="date"/>

                <!-- GENDER -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giới tính"
                    android:textColor="@color/app_text_primary"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"/>

                <RadioGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <RadioButton
                        android:id="@+id/rdNu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nữ"
                        android:textColor="@color/app_text_primary"/>

                    <RadioButton
                        android:id="@+id/rdNam"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nam"
                        android:textColor="@color/app_text_primary"
                        android:layout_marginStart="16dp"/>
                </RadioGroup>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BUTTON -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Lưu"
                android:textStyle="bold"
                android:textColor="@color/button_primary_text"
                android:backgroundTint="@color/button_primary_bg"
                android:layout_marginEnd="8dp"/>

            <Button
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hủy"
                android:textStyle="bold"
                android:textColor="@color/app_text_primary"
                android:backgroundTint="@color/app_surface_alt"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>

