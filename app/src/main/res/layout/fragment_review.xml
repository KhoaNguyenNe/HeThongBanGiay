<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_background"
    android:padding="16dp"
    tools:context=".activities.ReviewFragment">

    <!-- CARD ĐÁNH GIÁ -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        android:padding="16dp"
        android:backgroundTint="@color/app_surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
                android:id="@+id/imgSanPhamDanhGia"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_image"
                android:contentDescription="@string/cd_product_image"
                android:scaleType="centerCrop"
                android:src="@drawable/shoes" />

            <!-- TITLE -->
            <TextView
                android:id="@+id/txtTenSanPhamDanhGia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Đánh giá"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_primary"/>

            <!-- STAR -->
            <LinearLayout
                android:id="@+id/layoutStar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <ImageView
                    android:id="@+id/star1"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="4dp"
                    app:tint="@color/app_rating"
                    android:src="@drawable/ic_star_border" />

                <ImageView
                    android:id="@+id/star2"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="4dp"
                    app:tint="@color/app_rating"
                    android:src="@drawable/ic_star_border" />

                <ImageView
                    android:id="@+id/star3"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="4dp"
                    app:tint="@color/app_rating"
                    android:src="@drawable/ic_star_border" />

                <ImageView
                    android:id="@+id/star4"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="4dp"
                    app:tint="@color/app_rating"
                    android:src="@drawable/ic_star_border" />

                <ImageView
                    android:id="@+id/star5"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    app:tint="@color/app_rating"
                    android:src="@drawable/ic_star_border" />
            </LinearLayout>

            <!-- INPUT -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Viết đánh giá"
                android:textSize="16sp"
                android:textColor="@color/app_text_primary"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/edtReview"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:hint="Chia sẻ trải nghiệm của bạn..."
                android:textColor="@color/app_text_primary"
                android:textColorHint="@color/app_text_secondary"
                android:background="@drawable/bg_input_review"
                android:padding="12dp"
                android:gravity="top"
                android:inputType="textMultiLine"/>
            <Button
                android:id="@+id/btnSubmitReview"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:text="Gửi đánh giá"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="#FF4D4F" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>

